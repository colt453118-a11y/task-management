# ─── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://workmanager.example.com
NODE_ENV=production

# CSRF Protection — comma-separated additional allowed origins
CSRF_TRUSTED_ORIGINS=

# Database
DB_NAME=workmanagement
DB_USER=wmuser
DB_PASSWORD=change-me-to-a-secure-password

# Redis
REDIS_URL=redis://redis:6379
REDIS_PREFIX=wm:prod:

# Auth (Better Auth)
AUTH_SECRET=change-me-to-a-random-string
AUTH_URL=https://workmanager.example.com

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft OAuth
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=

# Storage (MinIO)
MINIO_ACCESS_KEY=change-me-to-secure-key
MINIO_SECRET_KEY=change-me-to-secure-secret
S3_BUCKET=workmanagement-files

# Search
MEILI_MASTER_KEY=change-me-to-secure-key

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@workmanager.example.com

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
