# ─── Application ──────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com
PORT=3000

# CSRF Protection
# Comma-separated list of additional allowed origins for CSRF validation.
# The APP_URL is always included automatically.
CSRF_TRUSTED_ORIGINS=

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgres://user:password@host:5432/workmanagement?sslmode=require"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000

# ─── Redis ────────────────────────────────────────────────
REDIS_URL="redis://:password@host:6379"
REDIS_PREFIX="wm:prod:"

# ─── Auth (Better Auth) ───────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="https://yourdomain.com"

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft OAuth
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=

# ─── Storage (S3-compatible) ──────────────────────────────
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=workmanagement-prod-files
S3_PUBLIC_URL=https://s3.us-east-1.amazonaws.com/workmanagement-prod-files

# ─── Search ───────────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch.internal:7700
MEILISEARCH_API_KEY=

# ─── Queue ────────────────────────────────────────────────
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=3

# ─── Email ────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── AI ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Monitoring ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=
