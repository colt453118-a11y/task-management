# ─── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL="postgres://dev:devpassword@localhost:5432/workmanagement"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PREFIX="wm:dev:"

# Auth (Better Auth)
AUTH_SECRET="change-me-to-a-random-string"
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft OAuth
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=

# Storage (MinIO for dev)
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=workmanagement-files
S3_PUBLIC_URL=http://localhost:9000

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev-master-key

# Queue
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@workmanagement.local

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
